<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notes Taking Webapp</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>

    <div class="main w-full min-h-screen bg-zinc-900 p-10 text-white">
        <a class="text-blue-500 inline-block mb-10" href="/">go Back to home</a>
        <div class="form p-10 text-white">
            <form action="/edit" method="post">

                <input class="block w-1/4 rounded-md outline-none px-5 py-2 bg-zinc-700 mb-4" type="text"
                    placeholder="Previous name" name="previous" value="<%= filename %>" readonly>

                <input class="block w-1/4 rounded-md outline-none px-5 py-2 bg-zinc-700 mb-4" type="text"
                    placeholder="New Name" name="newname">

                <input class="mt-2 rounded-md bg-yellow-500 px-5 py-2" type="submit" value="Edit Name"></input>


            </form>
        </div>


    </div>

    </div>
</body>

</html>