<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notes Taking Webapp</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>

    <div class="main w-full min-h-screen bg-zinc-900">
        <div class="form p-10 text-white">
            <form action="/create" method="post">

                <input class="block w-full rounded-md outline-none px-5 py-2 bg-zinc-700 mb-4" type="text"
                    placeholder="enter title of task" name="title">

                <textarea class="block w-full rounded-md outline-none px-5 py-2 bg-zinc-700 resize-none"
                    placeholder="enter description of task"  name="details"></textarea>

                <input class="mt-2 rounded-md bg-blue-500 px-5 py-2" type="submit" value="Create Task"></input>

            </form>
        </div>

        <div class="tasks flex flex-wrap gap-3 p-10">

            <% if(files.length> 0){%>
                <% files.forEach(function (val){%>
                    <div class=" task min-w-80  bg-zinc-800 rounded-xl p-5  ">
                        <h1 class="text-lg font-semibold text-white mb-2 tracking-tighter">
                           <%= val %>
                        </h1>
                        <div class="flex w-full justify-between items-center">
                                 <a class="text-blue-500 inline-block" href="/file/<%= val%>/">Read More</a>
                        <a class="text-gray-400" href="/edit/<%= val%>/">Edit Filename</a>
                        </div>
                       
                    </div>
                    <%}) %>
                        <% }else{%>
                            <h3 class="text-lg font-semibold text-white m-auto">No task Yet</h3>

                            <% } %>


        </div>


    </div>

    </div>
</body>

</html>