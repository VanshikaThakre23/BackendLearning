<%- include('./partials/header') %>

<%
// ====== EMPTY CART GUARD ======
if (!user.cart || user.cart.length === 0) {
%>
    <div class="w-full h-screen flex items-center justify-center">
        <h2 class="text-2xl">Your cart is empty 🛒</h2>
    </div>
    <%- include('./partials/footer') %>
    <% return; %>
<%
}

// ====== BASIC SETUP ======
const product = user.cart[0];
const quantity = 1;

// price safety
const price = product.price || 0;
const discount = product.discount || 0;
const platformFee = 20;
const shippingFee = 0;

const mrp = price * quantity;
const netTotal = mrp - discount;
const totalAmount = netTotal + platformFee + shippingFee;
%>

<div class="w-full h-screen flex items-start px-20 py-20 gap-10">

       <%# LEFT PRODUCT CARD %>
    <div class="w-[30%] rounded-md overflow-hidden">

   <%# PRODUCT IMAGE %>
       <div class="w-full flex justify-center items-center h-80 
     <%= product.bgcolor ? '' : 'bg-gray-800' %>"
     <% if (product.bgcolor) { %>
         style="background-color:<%= product.bgcolor %>"
     <% } %>>


            <% if (product.image) { %>
                <img class="h-[18rem]"
                     src="data:image/jpeg;base64,<%= product.image.toString('base64') %>"
                     alt="">
            <% } else { %>
                <div class="text-white text-sm">No Image Available</div>
            <% } %>

        </div>

       <%# PRODUCT NAME + QUANTITY %>
        <div class="w-full flex justify-between px-5 py-4">
            <h3 class="text-2xl"><%= product.name || "Unnamed Product" %></h3>

            <div class="flex items-center gap-2">
                <i class="w-7 h-7 bg-white flex rounded-full items-center justify-center ri-add-line"></i>

                <div class="px-2 py-1 rounded-md bg-white text-black">
                    <%= quantity %>
                </div>

                <i class="w-7 h-7 bg-white flex rounded-full items-center justify-center ri-subtract-line"></i>
            </div>
        </div>

        <%#//NET TOTAL %>
        <div class="text-white flex items-center justify-between px-5 py-3">
            <h4 class="text-lg">Net Total</h4>
            <h2 class="text-lg">₹ <%= netTotal %></h2>
        </div>
    </div>

  <%# RIGHT PRICE BREAKDOWN  %>
    <div class="w-[70%]">
        <h3 class="text-xl">Price Breakdown</h3>

        <div class="px-10 mt-5">

            <div class="flex mt-2">
                <h4 class="w-1/3">Total MRP</h4>
                <h4>₹ <%= mrp %></h4>
            </div>

            <div class="flex mt-2">
                <h4 class="w-1/3">Discount on MRP</h4>
                <h4>₹ <%= discount %></h4>
            </div>

            <div class="flex mt-2">
                <h4 class="w-1/3">Platform Fee</h4>
                <h4>₹ <%= platformFee %></h4>
            </div>

            <div class="flex mt-2">
                <h4 class="w-1/3">Shipping Fee</h4>
                <h4><%= shippingFee === 0 ? "FREE" : `₹ ${shippingFee}` %></h4>
            </div>

        </div>

        <div class="w-full h-[1px] bg-black mt-10"></div>

        <div class="flex mt-5">
            <h3 class="w-1/3 text-xl">Total Amount</h3>
            <h3 class="font-semibold text-xl text-green-600">
                ₹ <%= totalAmount %>
            </h3>
        </div>

        <form action=""></form>
    </div>

</div>

<%- include('./partials/footer') %>
