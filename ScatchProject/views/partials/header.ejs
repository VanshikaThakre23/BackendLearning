<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Scatch Website</title>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="font-['helvetica_now_display'] bg-gray-50">

    <nav class="w-full fixed top-0 left-0 z-50 bg-white shadow-sm px-8 py-4 flex items-center justify-between">
        <!-- Logo -->
        <h3 class="text-2xl font-semibold tracking-wide">Scatch</h3>

        <% var loggedin = typeof loggedin !== "undefined" ? loggedin : true %>

        <% if (loggedin) { %>
            <!-- Nav links -->
            <div class="flex items-center gap-6 text-xl font-medium text-gray-700">
                <a href="/shop" class="hover:text-black transition">Shop</a>
                <a href="/cart" class="hover:text-black transition">Cart</a>
                <a href="/account" class="hover:text-black transition">My Account</a>
                <a href="/user/logout" class="text-red-500 hover:text-red-600 transition">
                    Logout
                </a>
            </div>
        <% } %>
    </nav>

</body>
</html>
